# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/knowledgevault

# Ollama Configuration (External Server)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
OLLAMA_LLM_MODEL=qwen2:7b

# API Configuration
API_V1_PREFIX=/api/v1
INTERNAL_API_KEY=replace-with-a-random-service-key
CORS_ORIGINS=http://localhost:3000

# Document Processing
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE=52428800

# App Configuration
APP_NAME=KnowledgeVault AI Service
APP_VERSION=1.0.0
ENVIRONMENT=development
APP_DEBUG=false
