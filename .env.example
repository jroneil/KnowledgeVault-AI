# Database Configuration
POSTGRES_DB=knowledgevault
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password

# Backend Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/knowledgevault
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=replace-with-a-strong-password
SERVER_PORT=8080

# JWT Configuration
# IMPORTANT: Generate a secure random key for production!
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRATION=86400000

# Service-to-service authentication
INTERNAL_API_KEY=replace-with-a-random-service-key

# AI models
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
OLLAMA_LLM_MODEL=qwen2:7b

# Browser origin allowed by backend and AI service
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Runtime mode. Production rejects development-only AI service secrets.
ENVIRONMENT=development

# Optional administration service
PGADMIN_PASSWORD=replace-with-a-strong-password
